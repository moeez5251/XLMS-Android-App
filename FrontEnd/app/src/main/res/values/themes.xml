<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme -->
    <style name="Theme.XLMSAdmin" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_container</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/primary_container</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.XLMS.Splash" parent="Theme.XLMSAdmin">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
    </style>

    <!-- Client Navigation View Item Text Style -->
    <style name="ClientNavItemText" parent="android:Widget.TextView">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
    </style>

    <!-- Client Navigation Item Shape (rounded) -->
    <style name="ClientNavItemShape">
        <item name="cornerSize">10dp</item>
    </style>

</resources>
