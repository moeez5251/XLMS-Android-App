<?xml version="1.0" encoding="utf-8"?>
<FrameLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Soft Blue Gradient Background Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background_gradient_overlay" />

    <!-- Decorative Blur Elements (Background) -->
    <View
        android:layout_width="384dp"
        android:layout_height="384dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-192dp"
        android:layout_marginEnd="-192dp"
        android:background="@drawable/blur_gradient_circle"
        android:alpha="0.4" />

    <View
        android:layout_width="256dp"
        android:layout_height="256dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-128dp"
        android:layout_marginStart="-128dp"
        android:background="@drawable/blur_gradient_circle_primary"
        android:alpha="0.3" />

    <ScrollView 
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="64dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- Back Button -->

        <!-- Progress Indicator -->
        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="57dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginStart="-16dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_2_of_3"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.2"
                android:fontFamily="@font/inter" />

            <!-- Progress Bar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/pagination_dot_inactive" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/primary" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/pagination_dot_active" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="2dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@color/surface_container_high" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/pagination_dot_inactive" />
            </LinearLayout>
        </LinearLayout>

        <!-- Brand & Context -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="40dp">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/verification_icon_background"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_history_edu"
                    android:contentDescription="@null"
                    app:tint="@color/primary" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/verification_code_title"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:fontFamily="@font/manrope_extrabold"
                android:gravity="center"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/verification_subtitle"
                android:textSize="16sp"
                android:textColor="@color/secondary"
                android:fontFamily="@font/work_sans_regular"
                android:gravity="center"
                android:maxWidth="320dp" />
        </LinearLayout>

        <!-- Verification Canvas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/verification_card_background"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <!-- Top Accent Line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/button_primary_gradient"
                android:layout_marginBottom="24dp" />

            <!-- OTP Input Fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/editTextOtp1"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <EditText
                    android:id="@+id/editTextOtp2"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <EditText
                    android:id="@+id/editTextOtp3"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <EditText
                    android:id="@+id/editTextOtp4"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <EditText
                    android:id="@+id/editTextOtp5"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <EditText
                    android:id="@+id/editTextOtp6"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/otp_input_background"
                    android:inputType="number"
                    android:maxLength="1"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />
            </LinearLayout>

            <!-- Timer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="@null"
                    app:tint="@color/secondary" />

                <TextView
                    android:id="@+id/textViewTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/expires_in"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/inter" />
            </LinearLayout>

            <!-- Verify Button -->
            <Button
                android:id="@+id/buttonVerify"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/button_primary_gradient"
                android:text="@string/button_verify_access"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_bold"
                android:elevation="2dp" />

            <!-- Resend Code -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/didnt_receive_email"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/work_sans_regular" />

                <TextView
                    android:id="@+id/textViewResend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/button_resend_code"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="@font/inter"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Security Badges -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_verified_user"
                    android:contentDescription="@null"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/secure_access"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/inter" />
            </LinearLayout>

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/pagination_dot_inactive" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_gavel"
                    android:contentDescription="@null"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/academic_privacy"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface_variant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:fontFamily="@font/inter" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    </ScrollView>

</FrameLayout>
