<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Icon Container -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="120dp"
            android:background="@color/surface_container_low"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:id="@+id/noWifiIcon"
                android:layout_width="94dp"
                android:layout_height="97dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_wifi_off" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="No Internet Connection"
            android:textColor="@color/error"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Please check your network settings and try again to continue accessing your library."
            android:textColor="@color/on_surface_variant"
            android:textSize="18sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnReconnect"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Reconnect"
            android:background="@drawable/signature_gradient"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnExit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="Exit App"
            android:background="?attr/selectableItemBackground"
            android:textColor="@color/primary"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>


</RelativeLayout>
