<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@color/surface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resource Management"
                android:textSize="32sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/manrope_extrabold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refine the metadata and parameters of the XLMS Library ecosystem. Here, curators maintain the structural integrity of the Athenaeum's digital assets."
                android:textSize="14sp"
                android:textColor="@color/on_surface_variant"
                android:lineSpacingExtra="4dp"
                android:maxWidth="600dp" />
        </LinearLayout>

        <!-- Library Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_container_lowest">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_menu_book"
                        app:tint="@color/primary_container"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Library Details"
                        android:textSize="20sp"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/manrope_bold" />
                </LinearLayout>

                <!-- Library Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Library Name"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="4dp"
                        android:paddingStart="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/surface_container_high"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_temple"
                            app:tint="@color/primary_container"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="XLMS Central Athenaeum"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Institutional Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Institutional Email"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="4dp"
                        android:paddingStart="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/surface_container_high"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_mail"
                            app:tint="@color/primary_container"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="curator@xlms-library.org"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Repository URL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Official Repository URL"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="4dp"
                        android:paddingStart="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/surface_container_high"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_language"
                            app:tint="@color/primary_container"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="www.xlms-library.org"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Add New Resource Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <Button
                android:id="@+id/buttonAddResource"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/button_primary_gradient"
                android:text="Add New Resource"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:drawableStart="@drawable/ic_add_circle"
                android:drawablePadding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
