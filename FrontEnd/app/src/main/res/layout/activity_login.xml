<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Section with Background Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="265dp">

            <!-- Background Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/login_hero_background"
                android:scaleType="centerCrop"
                android:alpha="0.15"
                android:contentDescription="@string/hero_background_desc" />

            <!-- Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient_overlay" />

            <!-- Central Logo Branding -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/logo_circle_background"
                    android:elevation="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_auto_stories"
                        android:contentDescription="@string/logo_desc"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/app_name"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/manrope_extrabold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/splash_subtitle"
                    android:textSize="10sp"
                    android:textColor="@color/on_secondary_container"
                    android:textAllCaps="true"
                    android:letterSpacing="0.3"
                    android:fontFamily="@font/inter"
                    android:alpha="0.7" />
            </LinearLayout>
        </FrameLayout>

        <!-- Login Form Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingBottom="32dp">

            <!-- Welcome Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_back"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/access_your_collection"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/work_sans_regular" />
            </LinearLayout>

            <!-- Email Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_email_address"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/input_field_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_mail"
                            android:contentDescription="@null"
                            app:tint="@color/on_surface_variant" />

                        <EditText
                            android:id="@+id/editTextEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:background="@null"
                            android:hint="@string/hint_email"
                            android:inputType="textEmailAddress"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="@font/work_sans_regular" />
                    </LinearLayout>

                    <!-- Bottom accent line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom"
                        android:background="@color/primary"
                        android:alpha="0"
                        android:id="@+id/emailAccentLine" />
                </FrameLayout>
            </LinearLayout>

            <!-- Password Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="@font/inter"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/input_field_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_lock"
                            android:contentDescription="@null"
                            app:tint="@color/on_surface_variant" />

                        <EditText
                            android:id="@+id/editTextPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:background="@null"
                            android:hint="@string/hint_password"
                            android:inputType="textPassword"
                            android:textSize="16sp"
                            android:textColor="@color/on_surface"
                            android:fontFamily="@font/work_sans_regular" />

                        <ImageButton
                            android:id="@+id/buttonTogglePassword"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_lock"
                            android:contentDescription="@string/toggle_password"
                            app:tint="@color/on_surface_variant"
                            android:padding="8dp" />
                    </LinearLayout>

                    <!-- Bottom accent line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom"
                        android:background="@color/primary"
                        android:alpha="0"
                        android:id="@+id/passwordAccentLine" />
                </FrameLayout>
            </LinearLayout>

            <!-- Remember Me & Forgot Password -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <!-- Toggle Switch -->
                <LinearLayout
                    android:id="@+id/toggleRememberMe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical">

                        <!-- Switch Background Track -->
                        <View
                            android:id="@+id/switchBackground"
                            android:layout_width="44dp"
                            android:layout_height="24dp"
                            android:background="@drawable/switch_track_background" />

                        <!-- Switch Thumb (Circle) -->
                        <View
                            android:id="@+id/switchThumb"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="2dp"
                            android:background="@drawable/switch_thumb_circle"
                            android:elevation="2dp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/remember_me"
                        android:textSize="12sp"
                        android:textColor="@color/on_secondary_fixed_variant"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/textViewForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/inter"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/buttonLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/button_primary_background"
                android:text="@string/button_login"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_bold"
                android:elevation="4dp" />

            <!-- Sign Up Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_member"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/work_sans_regular" />

                <TextView
                    android:id="@+id/textViewRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/button_register"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/work_sans_medium"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Demo Credentials Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:padding="16dp"
                android:background="@drawable/demo_credentials_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/demo_credentials_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/inter_semibold"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/demo_admin_credentials"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/demo_client_credentials"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </LinearLayout>

        <!-- Decorative Background Elements -->
        <View
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-128dp"
            android:layout_marginBottom="-128dp"
            android:background="@drawable/decorative_circle_primary" />

        <View
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="-128dp"
            android:layout_marginTop="-128dp"
            android:background="@drawable/decorative_circle_tertiary" />

    </LinearLayout>
</ScrollView>
