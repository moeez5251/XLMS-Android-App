<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Layer 1 (Back): Background -->

    <!-- Layer 2 (Back): Decorative Circles -->
    <View
        android:id="@+id/decorativeElement1"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-100dp"
        android:background="@drawable/splash_decorative_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorativeElement2"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginEnd="-150dp"
        android:layout_marginBottom="-150dp"
        android:background="@drawable/splash_decorative_circle_secondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Layer 3 (Front): Central Branding Content -->
    <LinearLayout
        android:id="@+id/brandingContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Logo Icon Container -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/splash_logo_background"
            android:elevation="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_menu_book"
                android:contentDescription="@string/logo_desc"
                app:tint="@color/primary" />

            <View
                android:id="@+id/backgroundView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/surface" />
        </FrameLayout>

        <!-- App Title -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:includeFontPadding="false" />

        <!-- App Subtitle -->
        <TextView
            android:id="@+id/appSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/splash_subtitle"
            android:textSize="11sp"
            android:textColor="@color/on_primary_container"
            android:textAllCaps="true"
            android:letterSpacing="0.3"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Layer 4 (Front): Footer with Loading Indicator -->
    <LinearLayout
        android:id="@+id/footerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Loading Progress Bar -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="4dp"
            android:background="@drawable/splash_progress_background">

            <View
                android:id="@+id/progressBar"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:layout_gravity="start|center_vertical"
                android:background="@color/primary" />
        </FrameLayout>

        <!-- Version Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/system_initializing"
                android:textSize="9sp"
                android:textColor="@color/primary"
                android:textAllCaps="true"
                android:letterSpacing="0.2" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/splash_dot" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/primary"
                android:textAllCaps="true"
                android:letterSpacing="0.2"
                tools:text="Collection v1.0" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
