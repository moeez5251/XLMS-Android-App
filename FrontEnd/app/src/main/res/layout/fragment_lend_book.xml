<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/surface"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lend a Book"
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/manrope_bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- User Information Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Information"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/manrope_bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />
            </LinearLayout>

            <!-- Lender Name & Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lender Name"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editTextLenderName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background"
                        android:hint="e.g. Dr. Julian Thorne"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editTextEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background"
                        android:hint="j.thorne@academy.edu"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Phone Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/inter_semibold"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editTextPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_field_background"
                    android:hint="e.g. +1 234 567 890"
                    android:inputType="phone"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <!-- Book Information Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.15"
                    android:text="Book Information"
                    android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />
            </LinearLayout>

            <!-- Book Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Title"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/inter_semibold"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerBookTitle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_field_background"
                android:layout_marginBottom="16dp" />

            <!-- Category & Author -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Genre/Category"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerCategory"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Author"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background" />
                </LinearLayout>
            </LinearLayout>

            <!-- Lending Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lending Details"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:fontFamily="@font/manrope_bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:alpha="0.15" />
            </LinearLayout>

            <!-- Current Date & Due Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Date"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@color/surface_container_low">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            android:contentDescription="@null"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/textViewCurrentDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09/04/2026"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due Date"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editTextDueDate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background"
                        android:hint="Select due date"
                        android:focusable="false"
                        android:inputType="none"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Note: Return date must be after current date."
                        android:textSize="10sp"
                        android:textColor="@color/on_primary_container"
                        android:textStyle="italic"
                        android:layout_marginTop="4dp"
                        android:paddingStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Copies Lent & Per Day Fine -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copies Lent"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/editTextCopies"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_field_background"
                        android:hint="1"
                        android:inputType="number"
                        android:text="1"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Per Day Fine (Credits)"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="4dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp">

                        <EditText
                            android:id="@+id/editTextFine"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/input_field_background"
                            android:hint="0.00"
                            android:inputType="numberDecimal"
                            android:textColor="@color/on_surface"
                            android:textColorHint="@color/on_surface_variant"
                            android:textSize="14sp"
                            android:paddingStart="32dp"
                            android:paddingEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center_vertical"
                            android:layout_marginStart="12dp"
                            android:text="Rs"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:background="@color/surface_container_low"
            android:gravity="center">

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:text="Cancel"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/buttonLendBook"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/button_primary_gradient"
                android:text="Lend a Book"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="32dp"
                android:paddingEnd="32dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
