<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".ui.client.ClientDashboardActivity">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:background="@color/surface">

                <!-- Logo Icon -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu_book"
                    android:contentDescription="@null"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/xlms_library"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/manrope_extrabold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <!-- Notifications Bell -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp">

                    <ImageButton
                        android:id="@+id/buttonNotifications"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="@string/notifications"
                        android:padding="10dp"
                        app:tint="@color/primary" />

                    <!-- Red notification dot -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/notification_dot_background" />
                </FrameLayout>

                <!-- Profile Button with X Logo (Light Blue Background) -->
                <ImageButton
                    android:id="@+id/imageViewProfile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/profile_x_background"
                    android:src="@drawable/ic_x_logo"
                    android:contentDescription="Profile menu" />
            </LinearLayout>

            <!-- Subtle divider under app bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/outline_variant"
                android:alpha="0.2" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main Content Frame -->
        <FrameLayout
            android:id="@+id/mainContentFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surface" />

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:background="@color/surface_container_low"
            android:elevation="8dp"
            app:menu="@menu/client_bottom_navigation_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconSize="24dp"
            app:itemIconTint="@color/client_bottom_nav_color"
            app:itemTextColor="@color/client_bottom_nav_color"
            app:itemRippleColor="@color/primary_fixed" />

    </LinearLayout>

    <!-- Bottom Sheet Drawer -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Backdrop Overlay -->
        <View
            android:id="@+id/backdropOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:alpha="0"
            android:visibility="gone" />

        <!-- Bottom Sheet Content -->
        <LinearLayout
            android:id="@+id/bottomSheetContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@drawable/bottom_sheet_background"
            android:visibility="gone"
            android:paddingBottom="12dp"
            android:maxHeight="700dp">

            <!-- Grabber Handle -->
            <View
                android:layout_width="48dp"
                android:layout_height="6dp"
                android:background="@color/outline_variant"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Profile Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imageViewSheetProfile"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_account_circle"
                    android:scaleType="centerInside"
                    android:background="@drawable/profile_image_circle"
                    android:padding="10dp"
                    android:contentDescription="Profile"
                    android:layout_marginEnd="14dp"
                    app:tint="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textViewUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/manrope_extrabold" />

                    <TextView
                        android:id="@+id/textViewUserEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@example.com"
                        android:textSize="10sp"
                        android:textColor="@color/on_surface_variant"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:fontFamily="@font/inter_semibold" />

                    <TextView
                        android:id="@+id/textViewUserRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lead Researcher"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/role_badge_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/outline_variant"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="12dp" />

            <!-- ScrollView for Navigation Items -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="false"
                android:clipToPadding="false"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp">

                    <!-- Dashboard -->
                    <LinearLayout
                        android:id="@+id/navClientDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_dashboard"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dashboard"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <!-- Catalog -->
                    <LinearLayout
                        android:id="@+id/navClientCatalog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_menu_book"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Book Catalog"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <!-- Account -->
                    <LinearLayout
                        android:id="@+id/navClientAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_account_circle"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Account"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <!-- Help -->
                    <LinearLayout
                        android:id="@+id/navClientHelp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_help"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help &amp; Support"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <!-- Notifications -->
                    <LinearLayout
                        android:id="@+id/navClientNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/on_surface_variant"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textSize="15sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <!-- Logout Button (Red) - Pinned at Bottom -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/logout_button_background"
                android:text="Logout"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold"
                android:drawableStart="@drawable/ic_logout"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
