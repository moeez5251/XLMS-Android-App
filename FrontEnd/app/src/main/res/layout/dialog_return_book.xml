<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_extrabold"
            android:text="Return Confirmation"
            android:textColor="@color/primary"
            android:textSize="22sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_medium"
            android:text="Please review the book details before returning."
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/outline_variant"
            android:alpha="0.5" />

        <!-- Book Details Section -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:columnCount="2"
            android:rowCount="7">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Book Title"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogBookTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Excel Phenomenon"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Author -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Author"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogBookAuthor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="MM"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Category"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogBookCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Science Fiction"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Issued Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Issued Date"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogIssuedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="2026-05-07"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Due Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Due Date"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogDueDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="2026-05-08"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Copies -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Copies Lent"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/dialogCopiesLent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/inter_semibold"
                android:text="1"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />
        </GridLayout>

        <!-- Fine Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface_container_low"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Fine Details"
                    android:textColor="@color/primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_medium"
                        android:text="Per Day Fine"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/dialogPerDayFine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Rs. 100"
                        android:textColor="@color/on_surface"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_bold"
                        android:text="Total Payable Fine"
                        android:textColor="@color/on_surface"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/dialogTotalFine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_extrabold"
                        android:text="Rs. 0"
                        android:textColor="@color/error"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_bold"
                android:text="Cancel"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/on_surface"
                android:backgroundTint="@color/surface_container_high"
                app:cornerRadius="14dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogReturn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_bold"
                android:text="Return Book"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                app:cornerRadius="14dp"
                app:elevation="2dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
