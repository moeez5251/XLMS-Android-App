<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Notification List -->
    <LinearLayout
        android:id="@+id/layoutNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/surface"
            android:elevation="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notifications"
                android:textSize="20sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/manrope_bold" />

            <Button
                android:id="@+id/buttonClearAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackground"
                android:text="Clear All"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <!-- Notification List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewNotifications"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Empty State (Hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp"
        android:background="@color/surface">

        <!-- Centered Icon Container -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="24dp">

            <!-- Large Background Circle -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/empty_state_circle"
                android:layout_gravity="center" />

            <!-- Main Icon - Centered -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_notifications_off"
                android:layout_gravity="center"
                android:alpha="0.3" />
        </FrameLayout>

        <!-- Empty State Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Notifications"
            android:textSize="24sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/manrope_bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You're all caught up. Your scholarly updates will appear here."
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant"
            android:gravity="center"
            android:maxWidth="280dp"
            android:layout_marginBottom="24dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/buttonRefresh"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/button_primary_gradient"
                android:text="Refresh Feed"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
