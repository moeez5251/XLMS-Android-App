<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/stat_card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:id="@+id/iconBackground"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/icon_background_error">

            <ImageView
                android:id="@+id/statIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_report"
                android:contentDescription="@null"
                app:tint="@color/on_error_container" />
        </FrameLayout>

        <TextView
            android:id="@+id/statValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="0"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/error"
            android:fontFamily="@font/manrope_bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/statLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:text="@string/overdue_books"
        android:textSize="12sp"
        android:textColor="@color/on_surface_variant"
        android:fontFamily="@font/inter" />

    <TextView
        android:id="@+id/statLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/view_details"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/primary_container"
        android:fontFamily="@font/inter"
        android:drawableEnd="@drawable/ic_arrow_forward"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
